# Copia este archivo a .env y ajusta los valores.  (cp .env.example .env)

# --- Base de datos ---
# Local: SQLite.  Producción: PostgreSQL (ej: postgresql://user:pass@host:5432/db)
DATABASE_URL=sqlite:///./citafacil.db

# --- Seguridad ---
# Token para el panel de administración. ¡CÁMBIALO por uno propio!
ADMIN_TOKEN=cambia-este-token-admin

# Dominios permitidos para el frontend (separados por coma). * = todos.
CORS_ORIGINS=*

# --- Negocio ---
BUSINESS_NAME=Barbería Don Lucho
BUSINESS_TIMEZONE=America/Santiago
CURRENCY=CLP
OPEN_HOUR=10
CLOSE_HOUR=20
SLOT_INTERVAL_MINUTES=30
# Días cerrados (0=lunes ... 6=domingo). Ej "6" cierra domingo; "5,6" cierra fin de semana.
CLOSED_WEEKDAYS=6

# --- Twilio / WhatsApp ---
# Déjalos vacíos para MODO DEMO (los mensajes se registran en el log, no se envían).
# Complétalos para enviar WhatsApp reales.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de WhatsApp de Twilio (el sandbox de pruebas es whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Cuántas horas antes se envía el recordatorio, y cada cuánto revisa el sistema.
REMINDER_HOURS_BEFORE=24
REMINDER_POLL_MINUTES=15
